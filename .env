# ============================================================
# FICHIER .env — THENELLA Ministries
# ⚠️  Ne jamais partager ce fichier ni le pousser sur GitHub !
# ============================================================

# Environnement actif : development | production | testing
FLASK_ENV=development
FLASK_DEBUG=1

# Clé secrète (changez cette valeur par une chaîne aléatoire longue)
SECRET_KEY=thenella-secret-key-changez-moi-en-production-2024

# ------------------------------------------------------------
# BASE DE DONNÉES
# ------------------------------------------------------------
# SQLite pour le développement (le fichier sera créé automatiquement)
DATABASE_URL=sqlite:///thenella_dev.db

# ------------------------------------------------------------
# CONFIGURATION EMAIL (Gmail)
# ------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true

# Votre adresse Gmail utilisée pour envoyer les emails
MAIL_USERNAME=votre.email@gmail.com

# Mot de passe d'application Gmail (pas votre mot de passe habituel)
# Pour le générer : Google Account → Sécurité → Mots de passe d'application
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Adresse affichée comme expéditeur
MAIL_DEFAULT_SENDER=contact@thenellaministries.com

# ------------------------------------------------------------
# ADMINISTRATEUR
# ------------------------------------------------------------
# Email qui recevra les notifications de nouvelles réservations
ADMIN_EMAIL=admin@thenellaministries.com

# Identifiants du compte administrateur (dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-ce-mot-de-passe


MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=votre_email@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_application
MAIL_DEFAULT_SENDER=contact@thenellaministries.com
ADMIN_EMAIL=admin@thenellaministries.com